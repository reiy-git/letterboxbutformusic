<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="3" author="dev">
        <createTable tableName="reviews">
            <column name="reviewID" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="album_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="rating" type="INT">
                <constraints checkConstraint="rating BETWEEN 1 AND 5" nullable="false"/>
            </column>
            <column name="text" type="TEXT"/>
            <column name="is_deleted" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="deleted_at" type="TIMESTAMP WITH TIME ZONE"/>
        </createTable>
    </changeSet>

    <changeSet id="4" author="dev">
        <addForeignKeyConstraint
            baseTableName="reviews" baseColumnNames="user_id"
            referencedTableName="users" referencedColumnNames="userID"
            constraintName="fk_reviews_user"/>
        <addForeignKeyConstraint
            baseTableName="reviews" baseColumnNames="album_id"
            referencedTableName="albums" referencedColumnNames="albumID"
            constraintName="fk_reviews_album"/>
    </changeSet>

</databaseChangeLog>